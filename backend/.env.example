# Copy to backend/.env and fill in API keys.

DATABASE_URL=postgresql+asyncpg://devbrain_user:devbrain_pass@localhost:5432/devbrain_db
REDIS_URL=redis://localhost:6379/0

XAI_API_KEY=
GROK_MODEL=llama-3.3-70b-versatile
GROQ_FALLBACK_MODEL=llama-3.1-8b-instant

GITHUB_CLIENT_ID=
GITHUB_CLIENT_SECRET=
# Strongly recommended for GitHub analysis (manifests, commits, CI/CD probes)
GITHUB_PAT=

# GitHub OAuth app callback (must match GitHub app settings)
# Default: http://localhost:8000/auth/callback
BACKEND_URL=http://localhost:8000
FRONTEND_URL=http://localhost:3000

TAVILY_API_KEY=

JWT_SECRET_KEY=
JWT_ALGORITHM=HS256
JWT_EXPIRE_MINUTES=1440

FRONTEND_URL=http://localhost:3000
BACKEND_URL=http://localhost:8000

# Optional: suppress ChromaDB telemetry (also set in vector_store.py)
ANONYMIZED_TELEMETRY=False
